# Whisper-Input-Next environment template.
# Copy this file to .env and fill in only the services you use.

# ============ Transcription service ============
# doubao is the default streaming mode for Ctrl+F.
TRANSCRIPTION_SERVICE=doubao
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=

# Optional OpenAI batch transcription / translation.
OFFICIAL_OPENAI_API_KEY=

# Optional local whisper.cpp mode for Ctrl+I.
WHISPER_CLI_PATH=
WHISPER_MODEL_PATH=models/ggml-large-v3.bin

# ============ Keyboard and platform ============
TRANSCRIPTIONS_BUTTON=f
TRANSLATIONS_BUTTON=ctrl
# mac / linux / win
SYSTEM_PLATFORM=linux

# Default paste hotkey: linux=ctrl+shift+v, win=ctrl+v, mac=cmd+v.
# For non-terminal Linux apps, use PASTE_HOTKEY=ctrl+v if needed.
# PASTE_HOTKEY=ctrl+v

# ============ Feature switches ============
CONVERT_TO_SIMPLIFIED=false
ADD_SYMBOL=false
OPTIMIZE_RESULT=false
ENABLE_KIMI_POLISH=false
AUTO_RETRY_LIMIT=5

# ============ Status bar icons ============
# STATUS_ICON_IDLE=/path/to/idle.png
# STATUS_ICON_RECORDING=/path/to/recording.png
# STATUS_ICON_PROCESSING=/path/to/transcripting.png
# STATUS_ICON_TEMPLATE=true

# ============ Legacy compatible providers ============
GROQ_API_KEY=
GROQ_BASE_URL=
SILICONFLOW_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
